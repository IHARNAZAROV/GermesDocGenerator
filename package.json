{
  "name": "contract-generator",
  "productName": "Генератор договоров ГермесГарант",
  "version": "1.0.1",
  "description": "Генератор договоров агентства недвижимости ГермесГарант",
  "author": {
    "name": "INazarov",
    "email": "mail@germesgarant.by",
    "url": "https://germesgarant.by"
  },
  "homepage": "https://germesgarant.by",
  "license": "Proprietary",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "scan": "node scripts/scan-excel.js",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "docxtemplater": "^3.69.0",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "pizzip": "^3.2.0"
  },
  "build": {
    "appId": "by.germesgarant.contractgenerator",
    "artifactName": "${productName}-${version}.${ext}",
    "copyright": "© 2026 ООО ГермесГарант",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "**/*",
      "!release/**/*",
      "!build/**/*",
      "!scripts/**/*",
      "!*.log",
      "!README.md",
      "!attached_assets/**/*",
      "!output/**/*",
      "!.git/**/*",
      "!.agents/**/*",
      "!*.md",
      "!pyproject.toml",
      "!uv.lock",
      "!main.py",
      "!package-lock.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "portable": {
      "artifactName": "Генератор договоров ГермесГарант-Portable.exe"
    },
    "publish": {
    "provider": "github",
  "owner": "IHARNAZAROV",
  "repo": "GermesDocGenerator"},

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Генератор договоров ГермесГарант"
    }
  }
}
